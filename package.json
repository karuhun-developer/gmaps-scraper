{
  "name": "google-map-scraper",
  "version": "1.0.0",
  "description": "Google Maps Scraper API using Playwright + Hono",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:display": "xvfb-run --auto-servernum --server-args='-screen 0 1366x768x24' node src/index.js",
    "start:display": "xvfb-run --auto-servernum --server-args='-screen 0 1366x768x24' node src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:manual": "node tests/manual-test.js"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.7.7",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0"
  }
}
